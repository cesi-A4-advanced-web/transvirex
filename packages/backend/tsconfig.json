{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "incremental": true,
        "isolatedModules": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "noFallthroughCasesInSwitch": false,
        "noImplicitAny": false,
        "outDir": "./dist",
        "paths": {
            "@app/database": [
                "./libs/database/src"
            ],
            "@app/database/*": [
                "./libs/database/src/*"
            ],
            "@app/redis": [
                "./libs/redis/src"
            ],
            "@app/redis/*": [
                "./libs/redis/src/*"
            ],
            "@app/rabbitmq": [
                "./libs/rabbitmq/src"
            ],
            "@app/rabbitmq/*": [
                "./libs/rabbitmq/src/*"
            ],
            "@app/mongodb": [
                "./libs/mongodb/src"
            ],
            "@app/mongodb/*": [
                "./libs/mongodb/src/*"
            ],
            "@generated/prisma": [
                "./prisma/generated/prisma/client"
            ]
        },
        "removeComments": true,
        "resolvePackageJsonExports": true,
        "rootDir": "./",
        "skipLibCheck": true,
        "sourceMap": true,
        "strictBindCallApply": false,
        "strictNullChecks": true,
        "target": "ES2023"
    },
    "include": [
        "apps/**/*",
        "libs/**/*",
        "prisma/**/*",
        "prisma.config.ts"
    ]
}