{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "compilerOptions": {
        "builder": "tsc",
        "deleteOutDir": true
    },
    "monorepo": true,
    "projects": {
        "authentication": {
            "compilerOptions": {
                "tsConfigPath": "apps/authentication/tsconfig.app.json"
            },
            "entryFile": "main",
            "root": "apps/authentication",
            "sourceRoot": "apps/authentication/src",
            "type": "application"
        },
        "billing": {
            "compilerOptions": {
                "tsConfigPath": "apps/billing/tsconfig.app.json"
            },
            "entryFile": "main",
            "root": "apps/billing",
            "sourceRoot": "apps/billing/src",
            "type": "application"
        },
        "database": {
            "compilerOptions": {
                "tsConfigPath": "libs/database/tsconfig.lib.json"
            },
            "entryFile": "index",
            "root": "libs/database",
            "sourceRoot": "libs/database/src",
            "type": "library"
        },
        "delivery": {
            "compilerOptions": {
                "tsConfigPath": "apps/delivery/tsconfig.app.json"
            },
            "entryFile": "main",
            "root": "apps/delivery",
            "sourceRoot": "apps/delivery/src",
            "type": "application"
        },
        "gateway": {
            "compilerOptions": {
                "tsConfigPath": "apps/gateway/tsconfig.app.json"
            },
            "entryFile": "main",
            "root": "apps/gateway",
            "sourceRoot": "apps/gateway/src",
            "type": "application"
        },
        "guards": {
            "compilerOptions": {
                "tsConfigPath": "libs/guards/tsconfig.lib.json"
            },
            "entryFile": "index",
            "root": "libs/guards",
            "sourceRoot": "libs/guards/src",
            "type": "library"
        },
        "logging": {
            "compilerOptions": {
                "tsConfigPath": "libs/logging/tsconfig.lib.json"
            },
            "entryFile": "index",
            "root": "libs/logging",
            "sourceRoot": "libs/logging/src",
            "type": "library"
        },
        "mongodb": {
            "compilerOptions": {
                "tsConfigPath": "libs/mongodb/tsconfig.lib.json"
            },
            "entryFile": "index",
            "root": "libs/mongodb",
            "sourceRoot": "libs/mongodb/src",
            "type": "library"
        },
        "rabbitmq": {
            "compilerOptions": {
                "tsConfigPath": "libs/rabbitmq/tsconfig.lib.json"
            },
            "entryFile": "index",
            "root": "libs/rabbitmq",
