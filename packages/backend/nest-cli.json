        },
        "redis": {
            "compilerOptions": {
                "tsConfigPath": "libs/redis/tsconfig.lib.json"
            },
            "entryFile": "index",
            "root": "libs/redis",
            "sourceRoot": "libs/redis/src",
            "type": "library"
        },
        "stock": {
            "compilerOptions": {
                "tsConfigPath": "apps/stock/tsconfig.app.json"
            },
            "entryFile": "main",
            "root": "apps/stock",
            "sourceRoot": "apps/stock/src",
            "type": "application"
        },
        "users": {
            "compilerOptions": {
                "tsConfigPath": "apps/users/tsconfig.app.json"
            },
            "entryFile": "main",
            "root": "apps/users",
            "sourceRoot": "apps/users/src",
            "type": "application"
        }
    },
    "root": "apps/backend"
}
