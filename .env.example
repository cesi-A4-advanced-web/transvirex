# 🔐 Transvirex ERP - Environment Variables

# ===================================
# 🌐 Application Settings
# ===================================
NODE_ENV=development
APP_NAME=Transvirex ERP

# ===================================
# 💻 Frontend & API
# ===================================
FRONTEND_HOST=localhost
FRONTEND_PORT=3000
API_HOST=gateway-service
API_PORT=3000

# ===================================
# 🗄️ Database - PostgreSQL
# ===================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=transvirex

# ===================================
# 📨 Message Queue - RabbitMQ
# ===================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbitmq_user
RABBITMQ_PASSWORD=rabbitmq_password
RABBITMQ_MANAGEMENT_PORT=15672

# ===================================
# 🔴 Cache - Redis
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# ===================================
# 🍃 Database - MongoDB
# ===================================
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=mongo_user
MONGO_PASSWORD=mongo_password
MONGO_DB=transvirex
MONGODB_URI=mongodb://mongo_user:mongo_password@mongodb:27017/transvirex

# ===================================
# 🔐 Security & Authentication
# ===================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRATION=24h
# JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
# JWT_REFRESH_EXPIRATION=7d

# ===================================
# 📊 Logging & Monitoring
# ===================================
LOG_LEVEL=debug
# Backend logs are stored in 'banckend_logs' collection
# Frontend logs are stored in 'frontend_logs' collection

# # ===================================
# # 📧 Email (Optional - for notifications)
# # ===================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@transvirex.com

# ===================================
# ⚙️ Development Tools
# ===================================
DEBUG=*
